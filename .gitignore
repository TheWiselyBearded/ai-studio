# =============================================================================
# Secrets
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key

# =============================================================================
# AI Studio project artifacts
# =============================================================================
# Generation outputs — regenerated at runtime by the Unity windows / Flask API.
results/
input/
Unity_AI_Studio/AI_Studio_Engine/Assets/Generated3D/
Unity_AI_Studio/AI_Studio_Engine/Assets/GeneratedAudio/
Unity_AI_Studio/AI_Studio_Engine/Assets/GeneratedImages/
Unity_AI_Studio/AI_Studio_Engine/Assets/GeneratedVideos/
# …and their Unity .meta siblings.
Unity_AI_Studio/AI_Studio_Engine/Assets/Generated3D.meta
Unity_AI_Studio/AI_Studio_Engine/Assets/GeneratedAudio.meta
Unity_AI_Studio/AI_Studio_Engine/Assets/GeneratedImages.meta
Unity_AI_Studio/AI_Studio_Engine/Assets/GeneratedVideos.meta

# Voice clone local cache (populated by the Download-to-cache button).
Unity_AI_Studio/AI_Studio_Engine/Library/AIStudio/

# Deployment bundle — published as a GitHub release asset, not checked in.
ai-studio-light.zip
ai-studio-light/

# Model weights (should live on Lambda persistent filesystem, never in repo).
*.safetensors
*.ckpt
*.pt
*.pth
*.bin
*.gguf

